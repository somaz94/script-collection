# =============================================================================
# Kubespray Scripts - Shared Configuration
#
# All scripts source this file for common settings.
# Override any value with environment variables:
#   CONTROL_PLANE_USER=admin CONTROL_PLANE_HOST=10.0.0.1 ./check-version.sh
# =============================================================================

# Control Plane connection
CONTROL_PLANE_USER="${CONTROL_PLANE_USER:-your-user}"
CONTROL_PLANE_HOST="${CONTROL_PLANE_HOST:-your-control-plane-ip}"
CONTROL_PLANE="${CONTROL_PLANE_USER}@${CONTROL_PLANE_HOST}"

# Kubespray paths (on control plane)
KUBESPRAY_DIR="${KUBESPRAY_DIR:-~/kubespray}"
INVENTORY_NAME="${INVENTORY_NAME:-your-cluster}"

# Local paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_INVENTORY_DIR="${LOCAL_INVENTORY_DIR:-$SCRIPT_DIR/../inventory-${INVENTORY_NAME}}"
LOCAL_BACKUP_DIR="${LOCAL_BACKUP_DIR:-$SCRIPT_DIR/../backup}"

# Cluster info
EXPECTED_NODES="${EXPECTED_NODES:-4}"

# Node list for containerd/registry checks (space-separated)
CLUSTER_NODES="${CLUSTER_NODES:-10.0.0.1 10.0.0.2 10.0.0.3 10.0.0.4}"

# SSH options
SSH_OPTS="${SSH_OPTS:--o ConnectTimeout=5}"

# etcd cert paths (on control plane)
ETCD_CACERT="${ETCD_CACERT:-/etc/ssl/etcd/ssl/ca.pem}"
ETCD_CERT="${ETCD_CERT:-/etc/ssl/etcd/ssl/node-your-control-plane.pem}"
ETCD_KEY="${ETCD_KEY:-/etc/ssl/etcd/ssl/node-your-control-plane-key.pem}"

# Container registry
HARBOR_HOST="${HARBOR_HOST:-your-registry.example.com}"
